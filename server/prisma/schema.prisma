generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WAREHOUSE
  CASHIER
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RESTOCK
}

enum RestockStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum TransactionStatus {
  COMPLETED
  VOIDED
  HELD
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users            User[]
  stock            Stock[]
  transactions     Transaction[]
  restockRequests  RestockRequest[]
  heldTransactions HeldTransaction[]
  stockMovements   StockMovement[]
  shifts           CashierShift[]

  @@map("branches")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  branchId  String?  @map("branch_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch           Branch?          @relation(fields: [branchId], references: [id])
  transactions     Transaction[]
  stockMovements   StockMovement[]
  restockRequests  RestockRequest[]
  heldTransactions HeldTransaction[]
  shifts           CashierShift[]

  @@map("users")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@map("categories")
}

model Product {
  id         String   @id @default(uuid())
  name       String
  barcode    String   @unique
  categoryId String   @map("category_id")
  price      Decimal  @db.Decimal(12, 2)
  costPrice  Decimal  @db.Decimal(12, 2) @map("cost_price")
  unit       String   @default("pcs")
  imageUrl   String?  @map("image_url")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category         Category         @relation(fields: [categoryId], references: [id])
  stock            Stock[]
  transactionItems TransactionItem[]
  stockMovements   StockMovement[]
  restockRequests  RestockRequest[]

  @@map("products")
}

model Stock {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  branchId  String   @map("branch_id")
  quantity  Int      @default(0)
  minStock  Int      @default(5) @map("min_stock")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
  @@index([branchId])
  @@index([productId])
  @@map("stock")
}

model StockMovement {
  id        String            @id @default(uuid())
  productId String            @map("product_id")
  branchId  String            @map("branch_id")
  userId    String            @map("user_id")
  type      StockMovementType
  quantity  Int
  note      String?
  createdAt DateTime          @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([branchId])
  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

model RestockRequest {
  id                String        @id @default(uuid())
  branchId          String        @map("branch_id")
  productId         String        @map("product_id")
  requestedBy       String        @map("requested_by")
  quantityRequested Int           @map("quantity_requested")
  status            RestockStatus @default(PENDING)
  note              String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  branch    Branch  @relation(fields: [branchId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  requester User    @relation(fields: [requestedBy], references: [id])

  @@index([branchId])
  @@index([status])
  @@map("restock_requests")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions Transaction[]

  @@map("customers")
}

model Transaction {
  id            String            @id @default(uuid())
  invoiceNo     String            @unique @map("invoice_no")
  branchId      String            @map("branch_id")
  cashierId     String            @map("cashier_id")
  customerId    String?           @map("customer_id")
  subtotal      Decimal           @db.Decimal(12, 2)
  discount      Decimal           @default(0) @db.Decimal(12, 2)
  tax           Decimal           @default(0) @db.Decimal(12, 2)
  total         Decimal           @db.Decimal(12, 2)
  paidAmount    Decimal           @db.Decimal(12, 2) @map("paid_amount")
  changeAmount  Decimal           @db.Decimal(12, 2) @map("change_amount")
  paymentMethod PaymentMethod     @map("payment_method")
  status        TransactionStatus @default(COMPLETED)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  branch   Branch    @relation(fields: [branchId], references: [id])
  cashier  User      @relation(fields: [cashierId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  items    TransactionItem[]

  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

model TransactionItem {
  id            String  @id @default(uuid())
  transactionId String  @map("transaction_id")
  productId     String  @map("product_id")
  quantity      Int
  price         Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  subtotal      Decimal @db.Decimal(12, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items")
}

model HeldTransaction {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  cashierId String   @map("cashier_id")
  label     String?
  cartData  Json     @map("cart_data")
  createdAt DateTime @default(now()) @map("created_at")

  branch  Branch @relation(fields: [branchId], references: [id])
  cashier User   @relation(fields: [cashierId], references: [id])

  @@map("held_transactions")
}

model CashierShift {
  id          String      @id @default(uuid())
  branchId    String      @map("branch_id")
  cashierId   String      @map("cashier_id")
  status      ShiftStatus @default(OPEN)
  openingCash Decimal     @default(0) @db.Decimal(12, 2) @map("opening_cash")
  closingCash Decimal?    @db.Decimal(12, 2) @map("closing_cash")
  notes       String?
  openedAt    DateTime    @default(now()) @map("opened_at")
  closedAt    DateTime?   @map("closed_at")

  // Summary fields (computed and stored when shift is closed)
  totalTransactions Int     @default(0) @map("total_transactions")
  totalRevenue      Decimal @default(0) @db.Decimal(12, 2) @map("total_revenue")
  cashRevenue       Decimal @default(0) @db.Decimal(12, 2) @map("cash_revenue")

  branch  Branch @relation(fields: [branchId], references: [id])
  cashier User   @relation(fields: [cashierId], references: [id])

  @@index([branchId])
  @@index([cashierId, status])
  @@map("cashier_shifts")
}
